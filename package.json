{
	"name": "@sematico/flue-codex",
	"version": "0.2.0",
	"description": "Register subscription-backed OpenAI Codex models with Flue using local Codex CLI auth.",
	"type": "module",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/alessandrotesoro/flue-codex.git"
	},
	"homepage": "https://github.com/alessandrotesoro/flue-codex#readme",
	"bugs": {
		"url": "https://github.com/alessandrotesoro/flue-codex/issues"
	},
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./provider": {
			"types": "./dist/provider.d.ts",
			"import": "./dist/provider.js"
		},
		"./diagnostics": {
			"types": "./dist/diagnostics.d.ts",
			"import": "./dist/diagnostics.js"
		},
		"./auth": {
			"types": "./dist/auth.d.ts",
			"import": "./dist/auth.js"
		},
		"./runtime": {
			"types": "./dist/runtime.d.ts",
			"import": "./dist/runtime.js"
		},
		"./models": {
			"types": "./dist/models.d.ts",
			"import": "./dist/models.js"
		}
	},
	"bin": {
		"flue-codex-doctor": "dist/bin/flue-codex-doctor.js"
	},
	"files": [
		"dist",
		"LICENSE",
		"README.md",
		"examples"
	],
	"scripts": {
		"build": "tsup",
		"format": "biome format --write .",
		"lint": "biome lint .",
		"prepack": "pnpm build",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"test:live": "FLUE_CODEX_LIVE_SMOKE=1 vitest run test/live-smoke.test.ts"
	},
	"keywords": [
		"flue",
		"codex",
		"openai",
		"provider"
	],
	"license": "MIT",
	"publishConfig": {
		"access": "public"
	},
	"peerDependencies": {
		"@flue/runtime": "^1.0.0-beta.7"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.1",
		"@flue/runtime": "1.0.0-beta.7",
		"@types/node": "^24.0.0",
		"tsup": "^8.5.0",
		"typescript": "^5.9.0",
		"vitest": "^4.0.0"
	}
}
